# Required — Cursor Cloud Agents API key
# https://cursor.com/settings
CURSOR_API_KEY=your_api_key_here

# Recommended for HTTP / Perplexity remote connectors
MCP_AUTH_TOKEN=generate_a_long_random_secret

# HTTP server port (default: 3000)
PORT=3000

# Optional — auto-start ngrok and print public HTTPS URL for Perplexity
# Requires: ngrok installed and authenticated (ngrok config add-authtoken ...)
# TUNNEL=ngrok
